# CleanWave — API Keys
# Rename this file to .env and fill in at least one key.
# CleanWave uses Groq by default (free tier available at console.groq.com).
# If both are set, Groq takes priority.

GROQ_API_KEY=your_groq_key_here

# Optional: OpenRouter as fallback (openrouter.ai)
# OPENROUTER_API_KEY=your_openrouter_key_here
